# ─────────────────────────────────────────
# Cloud Command — Backend Environment
# ─────────────────────────────────────────

# Database (Neon PostgreSQL recommended for production)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Security (generate a strong random string for JWT_SECRET)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Fernet encryption key for API keys & tokens
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Email Notifications (Gmail SMTP with App Password)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_HOST=smtp.gmail.com
SMTP_SSL_PORT=465
SMTP_STARTTLS_PORT=587
SMTP_FORCE_IPV4=true

# Recommended on Render Free because SMTP ports are blocked there.
# Create a Resend API key and use a verified sender/domain.
RESEND_API_KEY=
MAIL_FROM_EMAIL=onboarding@your-domain.com
MAIL_FROM_NAME=Cloud Command

# Self-ping to prevent Render free tier sleep (optional)
RENDER_EXTERNAL_URL=https://your-backend.onrender.com
